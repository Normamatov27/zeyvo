# ── Dependencies ──────────────────────────────────────────────────────────────
FROM node:20-alpine AS deps
RUN corepack enable
WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY apps/web/package.json apps/web/
COPY packages/ui/package.json packages/ui/

RUN pnpm install --frozen-lockfile

# ── Build ─────────────────────────────────────────────────────────────────────
FROM node:20-alpine AS builder
RUN corepack enable
WORKDIR /app
# Copy the full deps tree so pnpm workspace links (apps/*/node_modules, packages/*/node_modules) survive
COPY --from=deps /app ./
COPY . .

# NEXT_PUBLIC_* are inlined at build time — must be passed as build-args.
ARG NEXT_PUBLIC_WS_URL=ws://localhost:8080
ARG NEXT_PUBLIC_TG_BOT_USERNAME=zeyvo_bot
ENV NEXT_PUBLIC_WS_URL=${NEXT_PUBLIC_WS_URL}
ENV NEXT_PUBLIC_TG_BOT_USERNAME=${NEXT_PUBLIC_TG_BOT_USERNAME}
ENV NEXT_TELEMETRY_DISABLED=1
RUN pnpm --filter web build

# ── Runtime ───────────────────────────────────────────────────────────────────
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup -S zeyvo && adduser -S zeyvo -G zeyvo

COPY --from=builder --chown=zeyvo:zeyvo /app/apps/web/.next/standalone ./
COPY --from=builder --chown=zeyvo:zeyvo /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=zeyvo:zeyvo /app/apps/web/public ./apps/web/public

USER zeyvo

EXPOSE 3000

CMD ["node", "apps/web/server.js"]
