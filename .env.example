# ── Database ─────────────────────────────────────────────
POSTGRES_DB=zeyvo
POSTGRES_USER=zeyvo
POSTGRES_PASSWORD=changeme

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-256-bit-secret-in-production
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_DAYS=30

# ── Telegram ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:AAABBBCCC
TELEGRAM_BOT_USERNAME=zeyvo_bot
TELEGRAM_WEBHOOK_SECRET=changeme

# ── SMS (DevSMS) ─────────────────────────────────────────
DEVSMS_BASE_URL=https://devsms.uz/api
DEVSMS_API_KEY=changeme
DEVSMS_SERVICE_NAME=Zeyvo
DEVSMS_TEMPLATE_TYPE=4

# ── Frontend ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_TG_BOT_USERNAME=zeyvo_bot

# ── Spring profile ───────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Deploy ───────────────────────────────────────────────
IMAGE_TAG=latest
DROPLET_HOST=your.droplet.ip
DROPLET_USER=root

# ── Spaces (nightly backup) ──────────────────────────────
SPACE_BUCKET=zeyvo-backups
AWS_ACCESS_KEY_ID=your_spaces_key
AWS_SECRET_ACCESS_KEY=your_spaces_secret
